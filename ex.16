numeros = []

for i in range(6):
    numero = int(input("Digite um número: "))
    numeros.append(numero)

n = len(numeros)

for i in range(n - 1):
    for j in range(n - 1 - i):
        if numeros[j] > numeros[j + 1]:
            aux = numeros[j]
            numeros[j] = numeros[j + 1]
            numeros[j + 1] = aux

print("Lista ordenada:", numeros)
